{
  "expo": {
    "name": "MinimalSudoku",
    "slug": "minimal-sudoku",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/icon.png",
    "scheme": "minimalsudoku",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/img/icon.png",
        "backgroundColor": "#ffcc19"
      },
      "package": "com.anonymous.minimalsudoku"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
