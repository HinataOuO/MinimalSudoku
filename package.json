{
  "name": "minimal-sudoku",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk:demo": "cd android && NODE_ENV=production ./gradlew clean assembleRelease --no-daemon --max-workers=2 -PreactNativeArchitectures=arm64-v8a -PnewArchEnabled=true -PhermesEnabled=true -Pandroid.enableBundleCompression=true -Pandroid.enableProguardInReleaseBuilds=true -Pandroid.enableShrinkResourcesInReleaseBuilds=true -Pexpo.useLegacyPackaging=true && cd .. && node scripts/check-apk-size.mjs",
    "postinstall": "patch-package",
    "typecheck": "tsc --noEmit",
    "test": "jest --cacheDirectory ./.jest-cache"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-constants": "~17.1.8",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-status-bar": "~2.2.3",
    "lucide-react-native": "^1.21.0",
    "nativewind": "4.1.23",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.15.5",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "13.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
